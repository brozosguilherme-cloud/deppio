# ============================================
# SUPABASE — Crie um projeto em supabase.com
# ============================================

# URL do projeto Supabase (ex: https://xyzabc.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública anon (usada no frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Chave service_role (NUNCA expor no frontend — apenas no servidor)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ============================================
# BANCO DE DADOS — String de conexão Prisma
# ============================================

# Connection pooling (para uso com Prisma via PgBouncer)
DATABASE_URL=postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Conexão direta (para migrations e prisma db push)
DIRECT_URL=postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ============================================
# APP
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
